 {
   "manifest_version": 3,
   "name": "Essence",
   "description": "AI-powered webpage summarizer that generates different types of summaries.",
   "version": "1.0",

   "permissions": ["scripting", "activeTab", "storage"],

   "icons": {
     "16": "essence_icon.png",
     "48": "essence_icon.png",
     "128": "essence_icon.png"
   },

   "action": {
     "default_popup": "popup.html",
     "default_icon": {
       "16": "essence_icon.png",
       "48": "essence_icon.png",
       "128": "essence_icon.png"
     }
   },

   "content_scripts": [
     {
       "matches": ["<all_urls>"],
       "js": ["content.js"]
     }
   ],

   "background": {
     "service_worker": "background.js"
   },

   "options_page": "options.html",

   "host_permissions": ["<all_urls>"]
 }